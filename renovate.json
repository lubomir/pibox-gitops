{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "argocd": {
    "managerFilePatterns": [
      "/clusters/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/clusters/.+\\.yaml$/"
    ]
  },
  "ignoreDeps": [],
  "packageRules": [
      {
          "matchDatasources": ["docker"],
          "matchPackageNames": ["code.forgejo.org/forgejo/runner"],
          "registryUrls": ["https://code.forgejo.org/v2"]
      }
  ]
}
